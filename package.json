{
  "name": "la-maria-qwik",
  "version": "1.0.0",
  "description": "La Maria Salsa Macha SPA built with Qwik and Cloudflare Pages",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.ssr": "vite build --ssr src/entry.ssr.tsx",
    "build.cloudflare": "vite build --ssr src/entry.cloudflare-pages.tsx --outDir dist",
    "dev": "vite",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js",
    "lint": "eslint \"src/**/*.ts*\"",
    "serve": "vite preview",
    "start": "wrangler pages dev ./dist"
  },
  "dependencies": {
    "@analytics/core": "^0.11.0",
    "@builder.io/qwik": "^1.12.0",
    "@builder.io/qwik-city": "^1.12.0",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.0",
    "qwik-speak": "^1.0.0",
    "tailwindcss": "4.0.0-beta.8",
    "uaparser.js": "^2.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wrangler": "^3.80.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
